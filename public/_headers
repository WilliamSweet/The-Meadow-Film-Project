/
  Cache-Control: no-cache, must-revalidate

/*.html
  Cache-Control: no-cache, must-revalidate

/images/*
  Cache-Control: no-cache, must-revalidate

/js/*
  Cache-Control: no-cache, must-revalidate

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cloud.umami.is https://tally.so; style-src 'self' 'unsafe-inline' https://tally.so; font-src 'self' https://tally.so; img-src 'self' data: https://tally.so; connect-src 'self' https://formspree.io https://cloud.umami.is https://tally.so; frame-src https://tally.so; frame-ancestors 'none';
