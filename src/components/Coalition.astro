---
const partners = [
  { name: 'Homegrown National Park', description: '250,000+ pledges to restore native habitat on private land across North America' },
  { name: 'Wild Ones', description: '36,000 members nationwide dedicated to native plant landscaping' },
  { name: 'Tallamy Lab, University of Delaware', description: "Doug Tallamy's research lab — the science behind native plants and the food web that this film is built on" },
];
---
<section class="coalition" id="coalition" aria-labelledby="coalition-heading">
  <div class="container">
    <h2 class="coalition-heading" id="coalition-heading">
      Leading native plant organizations are already on board.
    </h2>
    <ul class="coalition-list" aria-label="Confirmed coalition partners">
      {partners.map((partner) => (
        <li class="coalition-item">
          <span class="coalition-partner">{partner.name}</span>
          {partner.description && (
            <span class="coalition-description">{partner.description}</span>
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .coalition {
    padding: var(--space-24) 0;
    text-align: center;
  }

  .coalition-heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-16);
  }

  .coalition-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .coalition-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .coalition-partner {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .coalition-description {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.6;
    letter-spacing: 0;
    font-style: normal;
  }
</style>
