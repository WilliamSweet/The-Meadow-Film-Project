---
const details = [
  { label: 'Status',     value: 'In Production – 2026' },
  { label: 'Runtime',    value: '12–15 minutes' },
  { label: 'Director',   value: 'Wylie Overstreet' },
  { label: 'Producer',   value: 'Nick Lyon' },
  { label: 'Created by', value: 'William Sweet' },
  { label: 'Production', value: 'Painted Wolf Pictures' },
];
---
<section class="details" id="film" aria-labelledby="details-heading">
  <div class="container">
    <div class="details-inner">

      <div class="details-left">
        <h2 class="details-heading" id="details-heading">The Film</h2>
        <dl class="details-list">
          {details.map((item) => (
            <div class="details-row">
              <dt class="details-label">{item.label}</dt>
              <dd class="details-value">{item.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="details-image">
        <img
          class="img-details"
          src="/images/native-blackeyed-susan-meadow.webp"
          alt="Native black-eyed Susan meadow in bloom"
          width="960"
          height="640"
          loading="lazy"
        />
      </div>

    </div>
  </div>
</section>

<style>
  .details {
    padding: var(--space-24) 0;
  }

  .details-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-20);
    align-items: center;
  }

  .details-heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-12);
  }

  .details-list {
    max-width: 480px;
  }

  .details-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid rgba(201, 169, 110, 0.28);
  }

  .details-row:last-child {
    border-bottom: none;
  }

  .details-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-variant: small-caps;
    letter-spacing: 0.1em;
    color: var(--color-meadow);
    align-self: center;
  }

  .details-value {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .img-details {
    width: 100%;
    height: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
  }

  @media (max-width: 768px) {
    .details-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .details-image {
      order: -1;
    }

    .img-details {
      max-height: 280px;
    }
  }

  @media (max-width: 480px) {
    .details-row {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
