---
---
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav class="nav" id="nav" aria-label="Site navigation">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="The World's Best Office — return to top">The World's Best Office</a>

    <ul class="nav-links" role="list" aria-label="Page sections">
      <li><a href="#about"   class="nav-link" data-nav-link>About</a></li>
      <li><a href="#stories" class="nav-link" data-nav-link>Stories</a></li>
      <li><a href="#impact"  class="nav-link" data-nav-link>Impact</a></li>
      <li><a href="#team"    class="nav-link" data-nav-link>Team</a></li>
      <li><a href="#film"    class="nav-link" data-nav-link>Film</a></li>
    </ul>

    <a href="#founding-partner" class="btn btn-primary nav-cta">Join the Coalition</a>
  </div>
</nav>

<style>
  /* ── Base: solid background always — readable by default, no JS required ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: var(--space-4) 0;
    background-color: var(--color-bg);
    box-shadow: 0 1px 0 var(--color-straw);
    transition: background-color var(--duration-base) var(--ease-out-expo),
                box-shadow var(--duration-base) var(--ease-out-expo);
  }

  /* ── Over-hero: transparent + white text (progressive enhancement via JS) ── */
  .nav--over-hero {
    background-color: transparent;
    box-shadow: none;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* ── Logo ── */
  .nav-logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 900;
    letter-spacing: 0.14em;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color var(--duration-fast);
  }

  .nav--over-hero .nav-logo {
    color: #F7F3EC;
  }

  /* ── Section links ── */
  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--space-8);
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    font-variant: small-caps;
    letter-spacing: 0.12em;
    color: rgba(28, 43, 30, 0.55);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }

  .nav--over-hero .nav-link {
    color: rgba(247, 243, 236, 0.70);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-text);
    border-bottom-color: var(--color-earth);
    outline: none;
  }

  .nav--over-hero .nav-link:hover,
  .nav--over-hero .nav-link:focus-visible {
    color: #F7F3EC;
    border-bottom-color: rgba(247, 243, 236, 0.45);
  }

  .nav-link--active {
    color: var(--color-text);
    border-bottom-color: var(--color-earth);
  }

  .nav--over-hero .nav-link--active {
    color: #F7F3EC;
    border-bottom-color: rgba(247, 243, 236, 0.55);
  }

  /* ── CTA button ── */
  .nav-cta {
    padding: var(--space-2) var(--space-6);
    font-size: 0.625rem;
    flex-shrink: 0;
  }

  /* ── Mobile: hide section links; shrink logo so it never wraps ── */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .nav-logo {
      font-size: var(--text-sm);
      letter-spacing: 0.06em;
    }

    .nav-cta {
      padding: var(--space-2) var(--space-4);
      letter-spacing: 0.04em;
    }
  }
</style>

<script>
  /* ── Over-hero state: transparent when hero is visible, solid otherwise ── */
  const nav = document.getElementById('nav');
  const hero = document.querySelector('.hero');
  if (nav && hero) {
    new IntersectionObserver(
      ([entry]) => nav.classList.toggle('nav--over-hero', entry.isIntersecting),
      { threshold: 0 }
    ).observe(hero);
  }

  /* ── Scroll-spy: highlight the section currently in view ── */
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var links = Array.from(document.querySelectorAll('[data-nav-link]'));
    if (!links.length) return;

    var ids = links.map(function (l) { return l.getAttribute('href').slice(1); });
    var visible = new Set();

    function setActive() {
      var activeId = null;
      for (var i = 0; i < ids.length; i++) {
        if (visible.has(ids[i])) { activeId = ids[i]; break; }
      }
      links.forEach(function (l) {
        var id = l.getAttribute('href').slice(1);
        l.classList.toggle('nav-link--active', id === activeId);
      });
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          visible.add(e.target.id);
        } else {
          visible.delete(e.target.id);
        }
      });
      setActive();
    }, {
      rootMargin: '-80px 0px -35% 0px',
      threshold: 0
    });

    ids.forEach(function (id) {
      var el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  })();
</script>
