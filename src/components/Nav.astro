---
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav class="nav" id="nav" aria-label="Site navigation">
  <div class="nav-inner container">
    <a href="/" class="nav-logo" aria-label="meadowfilm.studio — return to top">meadowfilm.studio</a>

    <ul class="nav-links" role="list" aria-label="Page sections">
      <li><a href="#about"   class="nav-link" data-nav-link>About</a></li>
      <li><a href="#stories" class="nav-link" data-nav-link>Stories</a></li>
      <li><a href="#impact"  class="nav-link" data-nav-link>Impact</a></li>
      <li><a href="#team"    class="nav-link" data-nav-link>Team</a></li>
      <li><a href="#film"    class="nav-link" data-nav-link>Film</a></li>
    </ul>

    <a href="#founding-partner" class="btn btn-primary nav-cta">Join the Coalition</a>
  </div>
</nav>

<style>
  /* ── Animatable scroll-progress token ───────────────────────────────────────
     inherits: true so .nav-logo and .nav-link children can read it           */
  @property --nav-progress {
    syntax: '<number>';
    inherits: true;
    initial-value: 0;
  }

  /* ── Base: transparent, white text — works over hero with zero JS ── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: var(--space-4) 0;
    background-color: transparent;
    box-shadow: none;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  /* ── Logo ── */
  .nav-logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 900;
    letter-spacing: 0.14em;
    color: #F7F3EC;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
  }

  /* ── Section links ── */
  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--space-8);
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 400;
    font-variant: small-caps;
    letter-spacing: 0.12em;
    color: rgba(247, 243, 236, 0.70);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: #F7F3EC;
    border-bottom-color: rgba(247, 243, 236, 0.45);
    outline: none;
  }

  .nav-link--active {
    color: #F7F3EC;
    border-bottom-color: rgba(247, 243, 236, 0.55);
  }

  /* ── CTA button ── */
  .nav-cta {
    padding: var(--space-2) var(--space-6);
    font-size: 0.625rem;
    flex-shrink: 0;
  }

  /* ── JS fallback: solid state past hero (older browsers only) ── */
  .nav--scrolled {
    background-color: var(--color-bg);
    box-shadow: 0 1px 0 var(--color-straw);
    transition:
      background-color var(--duration-base) var(--ease-out-expo),
      box-shadow var(--duration-base) var(--ease-out-expo);
  }

  .nav--scrolled .nav-logo {
    color: var(--color-text);
    text-shadow: none;
    transition: color var(--duration-base) var(--ease-out-expo);
  }

  .nav--scrolled .nav-link {
    color: rgba(28, 26, 23, 0.55);
    text-shadow: none;
    transition: color var(--duration-base) var(--ease-out-expo);
  }

  .nav--scrolled .nav-link:hover,
  .nav--scrolled .nav-link:focus-visible {
    color: var(--color-text);
    border-bottom-color: var(--color-earth);
  }

  .nav--scrolled .nav-link--active {
    color: var(--color-text);
    border-bottom-color: var(--color-earth);
  }

  /* ── Cinematic CSS scroll-driven transition ─────────────────────────────────
     Background only — text color is handled by JS (.nav--scrolled class)
     Supported: Chrome 115+, Safari 18+, Firefox 110+
     180px fade window centred on the hero exit (100svh)              ── */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: scroll()) {

      @keyframes nav-bg {
        from { --nav-progress: 0; }
        to   { --nav-progress: 1; }
      }

      .nav {
        animation: nav-bg linear both;
        animation-timeline: scroll(root);
        animation-range: calc(100svh - 120px) calc(100svh + 60px);

        background-color: color-mix(
          in srgb,
          var(--color-bg) calc(var(--nav-progress) * 100%),
          transparent
        );
        box-shadow: 0 1px 0 color-mix(
          in srgb,
          var(--color-straw) calc(var(--nav-progress) * 100%),
          transparent
        );
      }
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .nav-logo {
      font-size: var(--text-sm);
      letter-spacing: 0.06em;
    }

    .nav-cta {
      padding: var(--space-2) var(--space-4);
      letter-spacing: 0.04em;
    }
  }
</style>
