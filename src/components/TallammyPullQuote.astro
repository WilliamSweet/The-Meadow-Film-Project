---
const quoteText = "A weed is a plant whose virtues have not yet been discovered.";
const words = quoteText.split(' ');
---
<div class="pull-quote" data-reveal>
  <div class="container">
    <p class="pull-quote-text">
      {words.map((word, i) => (
        <span class="word" style={`transition-delay: ${i * 50}ms`}>{word}{' '}</span>
      ))}
    </p>
    <p class="pull-quote-attribution">— Ralph Waldo Emerson</p>
  </div>
</div>

<style>
  .pull-quote {
    padding: var(--space-4) 0 var(--space-16);
    text-align: center;
  }

  .pull-quote-text {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.45;
    max-width: 50ch;
    margin: 0 auto var(--space-6);
  }

  .word {
    opacity: 0;
    transition: opacity 300ms ease-out;
    display: inline;
  }

  .pull-quote-text.revealed .word {
    opacity: 1;
  }

  /* Reduced motion: show words immediately, no animation */
  @media (prefers-reduced-motion: reduce) {
    .word {
      opacity: 1;
      transition: none;
    }
  }

  .pull-quote-attribution {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-wildflower);
    letter-spacing: 0.04em;
    margin: 0 auto;
  }
</style>
