---
const team = [
  {
    name: 'Nick Lyon',
    role: 'Producer',
    credential: "Director of Netflix's Our Oceans; co-creator of Prehistoric Planet",
    bio: "Nick directed Netflix's Our Oceans, narrated by President Obama, and co-created Prehistoric Planet for Apple TV+ alongside Jon Favreau. He spent four years directing the BBC's Dynasties: Painted Wolf, which won Best Behavioral Film at Jackson Hole. Over a twenty-five-year career his work has ranged from forest nomads in Sumatra to wolves on the Arctic tundra.",
    imgSrc: '/images/nick-lyon.webp',
    imgAlt: 'Nick Lyon, producer',
    imgW: 149,
    imgH: 200,
    imgPosition: 'center top',
  },
  {
    name: 'Wylie Overstreet',
    role: 'Director',
    credential: 'Creator of To Scale: The Solar System',
    bio: 'Wylie is a filmmaker whose visual storytelling has reached tens of millions worldwide. He created the To Scale series, including the viral To Scale: The Solar System, built across a seven-mile stretch of Nevada desert. His work has been featured by The Atlantic, The Guardian, Scientific American, and PBS.',
    imgSrc: '/images/wylie-overstreet.webp',
    imgAlt: 'Wylie Overstreet, director',
    imgW: 168,
    imgH: 200,
  },
  {
    name: 'Mel Finn',
    role: '',
    credential: 'Novelist — The Gloaming, The Underneath, The Hare',
    bio: 'Melanie is an award-winning novelist and documentary filmmaker. She brings a literary sensibility to non-fiction storytelling, exploring how we mythologize landscapes and how those myths shape the way we treat the land.',
    imgSrc: '/images/mel-finn.webp',
    imgAlt: 'Mel Finn',
    imgW: 154,
    imgH: 200,
  },
  {
    name: 'William Sweet',
    role: 'Creator',
    credential: 'Creator of the American Roots Act',
    bio: "William is the creator of the American Roots Act, a bipartisan legislative initiative to scale native meadow restoration through tax incentives. He has collaborated with Senator Richard Blumenthal, Senate Majority Leader Bob Duff, and Representative Tom O'Dea, and has been invited to participate in federal Farm Bill discussions.",
    imgSrc: '/images/william-sweet.webp',
    imgAlt: 'William Sweet, creator',
    imgW: 200,
    imgH: 200,
  },
];
---
<section class="team" id="team" aria-labelledby="team-heading">
  <div class="container">
    <h2 class="team-heading" id="team-heading">The Team</h2>
    <div class="team-grid">
      {team.map((member) => (
        <article class="team-card">
          <img
            class="team-portrait"
            src={member.imgSrc}
            alt={member.imgAlt}
            width={member.imgW}
            height={member.imgH}
            loading="lazy"
            style={member.imgPosition ? `object-position: ${member.imgPosition}` : undefined}
          />
          <div class="team-info">
            {member.role && <p class="team-role">{member.role}</p>}
            <h3 class="team-name">{member.name}</h3>
            <p class="team-credential">{member.credential}</p>
            <p class="team-bio">{member.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    padding: var(--space-24) 0;
  }

  .team-heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    max-width: 580px;
    line-height: 1.25;
    margin-bottom: var(--space-16);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-12) var(--space-16);
  }

  .team-card {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .team-portrait {
    width: 96px;
    height: 96px;
    min-width: 96px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    transition: opacity var(--duration-base) ease-out;
  }

  .team-portrait:hover {
    opacity: 0.82;
  }

  .team-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-top: var(--space-2);
  }

  .team-role {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-variant: small-caps;
    letter-spacing: 0.12em;
    color: var(--color-meadow); /* 5.74:1 on cream — WCAG AA */
  }

  .team-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.15;
  }

  .team-credential {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.65;
    margin-top: var(--space-1);
  }

  .team-bio {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    opacity: 0.8;
    margin-top: var(--space-3);
    max-width: 52ch;
  }

  @media (max-width: 640px) {
    .team-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 380px) {
    .team-card {
      flex-direction: column;
    }
  }
</style>
