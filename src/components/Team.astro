---
const team = [
  {
    name: 'Nick Lyon',
    role: 'Producer',
    credential: 'Director of Netflix’s Our Oceans; co-creator of Prehistoric Planet',
    imgAlt: '[REPLACE: headshot of Nick Lyon, producer — 1:1 ratio, circular crop]',
  },
  {
    name: 'Wylie Overstreet',
    role: 'Director',
    credential: 'Creator of To Scale: The Solar System',
    imgAlt: '[REPLACE: headshot of Wylie Overstreet, director — 1:1 ratio, circular crop]',
  },
  {
    name: 'Mel Finn',
    role: 'Writer',
    credential: 'Novelist (The Gloaming, The Hare); co-founder of BirdStory',
    imgAlt: '[REPLACE: headshot of Mel Finn, writer — 1:1 ratio, circular crop]',
  },
  {
    name: 'William Sweet',
    role: 'Creator',
    credential: 'Creator of the American Roots Act',
    imgAlt: '[REPLACE: headshot of William Sweet, creator — 1:1 ratio, circular crop]',
  },
];
---
<section class="team" id="team" aria-labelledby="team-heading">
  <div class="container">
    <h2 class="team-heading" id="team-heading">
      A Netflix director. A filmmaker with tens of millions of views.
    </h2>
    <div class="team-grid">
      {team.map((member) => (
        <article class="team-card">
          <!-- REPLACE: portrait photograph, 1:1, circular crop, data-replace="true" -->
          <div
            class="team-portrait"
            role="img"
            aria-label={member.imgAlt}
            data-replace="true"
          ></div>
          <div class="team-info">
            <p class="team-role">{member.role}</p>
            <h3 class="team-name">{member.name}</h3>
            <p class="team-credential">{member.credential}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    padding: var(--space-24) 0;
  }

  .team-heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    max-width: 580px;
    line-height: 1.25;
    margin-bottom: var(--space-16);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-12) var(--space-16);
  }

  .team-card {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .team-portrait {
    width: 96px;
    height: 96px;
    min-width: 96px;
    border-radius: 50%;
    background: #d4c9b8;
    transition: opacity var(--duration-base) ease-out;
    /* REPLACE WITH: headshot photograph, min 200×200px, circular crop */
  }

  .team-portrait:hover {
    opacity: 0.82;
  }

  .team-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-top: var(--space-2);
  }

  .team-role {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-variant: small-caps;
    letter-spacing: 0.12em;
    color: var(--color-meadow); /* 5.74:1 on cream — WCAG AA */
  }

  .team-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.15;
  }

  .team-credential {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text);
    opacity: 0.65;
    margin-top: var(--space-1);
  }

  @media (max-width: 640px) {
    .team-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 380px) {
    .team-card {
      flex-direction: column;
    }
  }
</style>
