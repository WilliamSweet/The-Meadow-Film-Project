---
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import FilmPremise from '../components/FilmPremise.astro';
import ImpactStats from '../components/ImpactStats.astro';
import FilmDetails from '../components/FilmDetails.astro';
import Location from '../components/Location.astro';
import Team from '../components/Team.astro';
import Coalition from '../components/Coalition.astro';
import StoriesSection from '../components/StoriesSection.astro';
import MeadowBreak from '../components/MeadowBreak.astro';
import FoundingPartnerCTA from '../components/FoundingPartnerCTA.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="The World's Best Office — a documentary film about the American lawn and what comes back when we let it go. Join the founding coalition before registration closes July 1, 2026."
    />
    <meta name="robots" content="index, follow" />

    <!--
      Font preloads: update these paths after running `npm run build` and inspecting
      dist/_astro/ to find the actual hashed filenames for the WOFF2 files.
      Then replace the href values below.
    -->
    <!--
    <link rel="preload" href="/path/to/fraunces-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/path/to/dm-sans-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
    -->

    <title>The World's Best Office — Documentary Film</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
  </head>
  <body>
    <!--
      Nav outputs the skip link as its first element, making it the first
      interactive element in <body> — correct WCAG pattern.
    -->
    <Nav />

    <main id="main-content" tabindex="-1">
      <!-- SECTION 1: Hero — full-viewport, primary CTA above fold -->
      <Hero />

      <hr class="section-rule" aria-hidden="true" />

      <!-- SECTION 2: Film premise copy -->
      <FilmPremise />

      <hr class="section-rule" aria-hidden="true" />

      <!-- SECTION 3: Stories — five named subjects; character before statistics -->
      <StoriesSection />

      <!-- Visual landmark — full-bleed meadow break between stories and stats -->
      <MeadowBreak />

      <hr class="section-rule" aria-hidden="true" />

      <!-- SECTION 4: Three statistics — after visitor has met the people -->
      <ImpactStats />

      <hr class="section-rule" aria-hidden="true" />

      <!-- SECTION 5: Coalition partners — social proof -->
      <Coalition />

      <hr class="section-rule" aria-hidden="true" />

      <!-- SECTION 6: Primary location — Sleepy Cat Farm -->
      <Location />

      <hr class="section-rule" aria-hidden="true" />

      <!-- SECTION 7: Team — 2×2 grid, portrait + name + role -->
      <Team />

      <hr class="section-rule" aria-hidden="true" />

      <!-- SECTION 8: Film details — definition list -->
      <FilmDetails />

      <!-- SECTION 7: Founding Partner CTA — meadow green background -->
      <FoundingPartnerCTA />
    </main>

    <!-- SECTION 8: Footer — dark green -->
    <Footer />

    <!--
      Fathom Analytics — cookieless, no consent banner required.
      TODO: Replace YOUR_SITE_ID with your Fathom site ID before launch.
      TODO: Compute SRI hash via: curl https://cdn.usefathom.com/script.js | openssl dgst -sha384 -binary | openssl base64 -A
      Then add: integrity="sha384-HASH" crossorigin="anonymous"
    -->
    <!-- <script src="https://cdn.usefathom.com/script.js" data-site="YOUR_SITE_ID" defer></script> -->

    <script src="https://unpkg.com/@formspree/ajax@1" defer></script>
    <script defer>
      Formspree.init({ formId: 'mqeonzoz' });
    </script>

    <script defer src="https://cloud.umami.is/script.js" data-website-id="ba135a4e-288e-4632-95c5-26a0b5ed6f46"></script>

    <script>
      // On load: strip any hash left in the URL (prevents scroll-to-section
      // on refresh after a user previously clicked a CTA anchor).
      window.addEventListener('load', function () {
        if (window.location.hash) {
          window.scrollTo(0, 0);
          history.replaceState(null, '', window.location.pathname);
        }
        document.documentElement.style.scrollBehavior = 'smooth';
      });

      // After each anchor-link click, strip the hash once the scroll settles
      // so it does not persist in the URL for the next page load.
      document.querySelectorAll('a[href^="#"]').forEach(function (link) {
        link.addEventListener('click', function () {
          setTimeout(function () {
            history.replaceState(null, '', window.location.pathname);
          }, 800);
        });
      });

      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );

        var sections = document.querySelectorAll('main section');
        sections.forEach(function (el, i) {
          if (i === 0) return;
          el.setAttribute('data-reveal', '');
          observer.observe(el);
        });

        var footer = document.querySelector('footer');
        if (footer) {
          footer.setAttribute('data-reveal', '');
          observer.observe(footer);
        }
      })();
    </script>
  </body>
</html>
