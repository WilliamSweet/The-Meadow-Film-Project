---
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import FilmPremise from '../components/FilmPremise.astro';
import ImpactStats from '../components/ImpactStats.astro';
import FilmDetails from '../components/FilmDetails.astro';
import Location from '../components/Location.astro';
import Team from '../components/Team.astro';
import Coalition from '../components/Coalition.astro';
import StoriesSection from '../components/StoriesSection.astro';
import TallammyPullQuote from '../components/TallammyPullQuote.astro';
import MeadowBreak from '../components/MeadowBreak.astro';
import FoundingPartnerCTA from '../components/FoundingPartnerCTA.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Over 40 million acres of American lawn — more than cotton, rice, potatoes, and every fruit, nut, and berry orchard in the country combined. A documentary short about the Americans who turned it back into something alive."
    />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content="https://meadowfilm.studio/" />
    <meta property="og:title"       content="A Documentary Short About the American Yard" />
    <meta property="og:description" content="A short documentary about Americans who turned their lawns into native meadows, and what came back. A portrait of the country as it actually is." />
    <meta property="og:image"       content="https://meadowfilm.studio/images/hero-meadow.webp" />

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="A Documentary Short About the American Yard" />
    <meta name="twitter:description" content="A short documentary about Americans who turned their lawns into native meadows, and what came back. A portrait of the country as it actually is." />
    <meta name="twitter:image"       content="https://meadowfilm.studio/images/hero-meadow.webp" />

    <title>A Documentary Short About the American Yard</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
  </head>
  <body>
    <!--
      Nav outputs the skip link as its first element, making it the first
      interactive element in <body> — correct WCAG pattern.
    -->
    <Nav />

    <main id="main-content" tabindex="-1">
      <!-- SECTION 1: Hero — full-viewport, primary CTA above fold -->
      <Hero />

      <!-- SECTION 2: Film premise copy -->
      <FilmPremise />

      <!-- SECTION 3: Stories — five named subjects; character before statistics -->
      <StoriesSection />

      <!-- Pull-quote: lifts Tallamy's line as a cinematic pause before the stats -->
      <TallammyPullQuote />

      <!-- Visual landmark — full-bleed meadow break between stories and stats -->
      <MeadowBreak />

      <!-- SECTION 4: Three statistics — after visitor has met the people -->
      <ImpactStats />

      <!-- SECTION 5: Coalition partners — social proof -->
      <Coalition />

      <!-- SECTION 6: Primary location — Sleepy Cat Farm -->
      <Location />

      <!-- SECTION 7: Team — 2×2 grid, portrait + name + role -->
      <Team />

      <!-- SECTION 8: Film details — definition list -->
      <FilmDetails />

      <!-- SECTION 7: Founding Partner CTA — two tracks: org + individual -->
      <FoundingPartnerCTA />
    </main>

    <!-- SECTION 8: Footer — dark green -->
    <Footer />

    <!--
      Fathom Analytics — cookieless, no consent banner required.
      TODO: Replace YOUR_SITE_ID with your Fathom site ID before launch.
      TODO: Compute SRI hash via: curl https://cdn.usefathom.com/script.js | openssl dgst -sha384 -binary | openssl base64 -A
      Then add: integrity="sha384-HASH" crossorigin="anonymous"
    -->
    <!-- <script src="https://cdn.usefathom.com/script.js" data-site="YOUR_SITE_ID" defer></script> -->

    <script src="/js/formspree-ajax.js" defer></script>
    <script async defer src="https://cloud.umami.is/script.js" data-website-id="ba135a4e-288e-4632-95c5-26a0b5ed6f46"></script>
    <script src="/js/main.js?v=2" defer></script>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {

        // Hero text drifts upward at a faster rate than the background — classic parallax depth
        gsap.to('.hero-content', {
          yPercent: -22,
          ease: 'none',
          scrollTrigger: {
            trigger: '.hero',
            start: 'top top',
            end: 'bottom top',
            scrub: 1.5,
          }
        });

        // MeadowBreak: image travels at a different rate than the scroll — the grasses seem to breathe
        gsap.fromTo('.meadow-break-img',
          { yPercent: -14 },
          {
            yPercent: 14,
            ease: 'none',
            scrollTrigger: {
              trigger: '.meadow-break',
              start: 'top bottom',
              end: 'bottom top',
              scrub: true,
            }
          }
        );

        // FilmPremise: image slides in from the right as the section reveals
        // FilmPremise: intentionally static — no entrance animation (data-static on section).

        // CTA: content rises on enter — no opacity, parent section fades via [data-reveal]
        gsap.from('.cta-inner', {
          y: 45,
          duration: 1.1,
          ease: 'power2.out',
          scrollTrigger: {
            trigger: '.cta',
            start: 'top 80%',
            toggleActions: 'play none none none',
          }
        });

        // Story dark panels: background photo scrolls at a different rate than the card text
        // Creates depth — the landscape drifts while the person's story stays centered
        document.querySelectorAll('.story-bg-img').forEach((img) => {
          gsap.fromTo(img,
            { yPercent: -8 },
            {
              yPercent: 8,
              ease: 'none',
              scrollTrigger: {
                trigger: img.closest('.story-panel'),
                start: 'top bottom',
                end: 'bottom top',
                scrub: true,
              }
            }
          );
        });

      }
    </script>
  </body>
</html>
